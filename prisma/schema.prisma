// MES MVP - Prisma Schema
// Event-driven Manufacturing Execution System
// Aligned with ISA-95 Level 3 concepts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// EVENTS TABLE (Source of Truth)
// All critical operations emit immutable events
// =============================================================================

model Event {
  id             String   @id @default(uuid())
  timestampUtc   DateTime @default(now()) @map("timestamp_utc")
  eventType      String   @map("event_type")
  siteId         String   @map("site_id")
  stationId      String?  @map("station_id")
  workOrderId    String?  @map("work_order_id")
  unitId         String?  @map("unit_id")
  operatorId     String?  @map("operator_id")
  payload        Json
  source         String   // ui | edge | integration
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([workOrderId])
  @@index([unitId])
  @@index([stationId, timestampUtc])
  @@index([siteId, timestampUtc])
  @@map("events")
}

// =============================================================================
// CONFIGURATION ENTITIES (Admin-managed)
// =============================================================================

model Site {
  id       String    @id @default(uuid())
  name     String
  timezone String    @default("UTC")
  config   Json      @default("{}")
  active   Boolean   @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stations        Station[]
  workOrders      WorkOrder[]
  downtimeReasons DowntimeReason[]
  users           User[]           @relation("UserSites")
  aiInsights      AIInsight[]
  aiConversations AIConversation[]
  shifts          Shift[]

  @@map("sites")
}

model Station {
  id            String  @id @default(uuid())
  siteId        String  @map("site_id")
  name          String
  stationType   String  @map("station_type") // winding | assembly | test | inspection
  sequenceOrder Int     @map("sequence_order")
  config        Json    @default("{}")
  active        Boolean @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  site                 Site                      @relation(fields: [siteId], references: [id])
  operations           WorkOrderOperation[]
  unitExecutions       UnitOperationExecution[]
  downtimeIntervals    DowntimeInterval[]
  materialConsumptions UnitMaterialConsumption[]
  ncrs                 NonconformanceRecord[]
  aiInsights           AIInsight[]
  bomItems             BillOfMaterial[]
  assignedUsers        User[]                    @relation("AssignedStation")
  processStepDefinitions ProcessStepDefinition[]

  @@index([siteId])
  @@map("stations")
}

model DowntimeReason {
  id          String  @id @default(uuid())
  siteId      String  @map("site_id")
  code        String
  description String
  lossType    String  @map("loss_type") // equipment | changeover | material | quality | planned | other
  isPlanned   Boolean @default(false) @map("is_planned")
  active      Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site              Site               @relation(fields: [siteId], references: [id])
  downtimeIntervals DowntimeInterval[]

  @@unique([siteId, code])
  @@map("downtime_reasons")
}

model QualityCheckDefinition {
  id         String   @id @default(uuid())
  name       String
  checkType  String   @map("check_type") // pass_fail | measurement | checklist
  parameters Json     // Check-specific config (limits, options, etc.)
  stationIds String[] @map("station_ids")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  results QualityCheckResult[]

  @@map("quality_check_definitions")
}

model Routing {
  id             String    @id @default(uuid())
  name           String
  description    String?
  productCode    String    @map("product_code")
  serialFormat   String?   @map("serial_format") // e.g., "BLDC-{YYYY}-{SEQ:5}"
  operations     Json      // Array of { stationId, sequence, estimatedMinutes }
  revision       String    @default("A")
  effectiveDate  DateTime? @map("effective_date")
  supersededById String?   @map("superseded_by_id")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  supersededBy      Routing?        @relation("RoutingRevision", fields: [supersededById], references: [id])
  previousRevisions Routing[]       @relation("RoutingRevision")
  workOrders        WorkOrder[]
  bom               BillOfMaterial[]
  eolTestSuites     EolTestSuite[]

  @@map("routings")
}

model BillOfMaterial {
  id            String  @id @default(uuid())
  routingId     String  @map("routing_id")
  stationId     String  @map("station_id")
  materialCode  String  @map("material_code")
  description   String?
  qtyPerUnit    Float   @map("qty_per_unit")
  unitOfMeasure String  @default("EA") @map("unit_of_measure")
  assemblyGroup String? @map("assembly_group") // stator | rotor | wire_harness | base | final_assembly
  sortOrder     Int     @default(0) @map("sort_order")
  active        Boolean @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  routing Routing @relation(fields: [routingId], references: [id])
  station Station @relation(fields: [stationId], references: [id])

  @@unique([routingId, materialCode, stationId])
  @@index([routingId])
  @@map("bill_of_materials")
}

// =============================================================================
// USER & RBAC
// =============================================================================

enum Role {
  operator
  supervisor
  admin
  buyer
  receiving_mgr
  qa_inspector
  supply_chain_mgr
  shipping_coordinator
}

model User {
  id                String   @id @default(uuid())
  clerkId           String   @unique @map("clerk_id")
  email             String   @unique
  name              String
  role              Role     @default(operator)
  assignedStationId String?  @map("assigned_station_id")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  assignedStation      Station?                  @relation("AssignedStation", fields: [assignedStationId], references: [id])
  sites                Site[]                    @relation("UserSites")
  unitExecutions       UnitOperationExecution[]
  downtimeIntervals    DowntimeInterval[]
  materialConsumptions UnitMaterialConsumption[]
  qualityResults       QualityCheckResult[]
  auditLogs            AuditLog[]
  aiConversations      AIConversation[]
  receivedMaterialLots MaterialLot[]             @relation("ReceivedMaterialLots")
  kitsCreated          Kit[]                     @relation("KitCreator")
  kitsIssued           Kit[]                     @relation("KitIssuer")
  kitLinesPicked       KitLine[]                 @relation("KitLinePicker")
  ctqMeasurements         CTQMeasurement[]
  stepDataCaptures        StepDataCapture[]
  inventoryTransactions   InventoryTransaction[]  @relation("InventoryTransactions")
  iqcInspections          IncomingInspection[]    @relation("IQCInspector")
  iqcApprovals            IncomingInspection[]    @relation("IQCApprover")
  iqcResults              IQCResult[]             @relation("IQCResultInspector")
  shipments               Shipment[]              @relation("ShipmentShipper")
  notifications           Notification[]
  apiKeys                 ApiKey[]                @relation("ApiKeyCreator")

  @@map("users")
}

// =============================================================================
// EXECUTION ENTITIES
// =============================================================================

model WorkOrder {
  id               String    @id @default(uuid())
  siteId           String    @map("site_id")
  routingId        String?   @map("routing_id")
  orderNumber      String    @unique @map("order_number")
  productCode      String    @map("product_code")
  productName      String?   @map("product_name")
  qtyOrdered       Int       @map("qty_ordered")
  qtyCompleted     Int       @default(0) @map("qty_completed")
  qtyScrap         Int       @default(0) @map("qty_scrap")
  status           String    @default("draft") // draft | pending | released | kitting | in_progress | in_testing | completed | shipped | cancelled
  priority         Int       @default(0)
  draftedAt        DateTime? @default(now()) @map("drafted_at")
  releasedAt       DateTime? @map("released_at")
  kittingStartedAt DateTime? @map("kitting_started_at")
  testingStartedAt DateTime? @map("testing_started_at")
  completedAt      DateTime? @map("completed_at")
  shippedAt        DateTime? @map("shipped_at")
  dueDate          DateTime? @map("due_date")
  customerName     String?   @map("customer_name")
  customerOrderRef String?   @map("customer_order_ref")
  targetStartDate  DateTime? @map("target_start_date")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  site         Site                   @relation(fields: [siteId], references: [id])
  routing      Routing?               @relation(fields: [routingId], references: [id])
  units        Unit[]
  operations   WorkOrderOperation[]
  kit          Kit?
  reservations InventoryReservation[]
  shipments    Shipment[]

  @@index([siteId, status])
  @@index([orderNumber])
  @@map("work_orders")
}

// =============================================================================
// INVENTORY RESERVATIONS (FIFO Auto-Reservation)
// =============================================================================

model InventoryReservation {
  id            String   @id @default(uuid())
  workOrderId   String   @map("work_order_id")
  materialLotId String   @map("material_lot_id")
  materialCode  String   @map("material_code")
  qtyReserved   Float    @map("qty_reserved")
  status        String   @default("active") // active | released | consumed
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workOrder   WorkOrder   @relation(fields: [workOrderId], references: [id])
  materialLot MaterialLot @relation(fields: [materialLotId], references: [id])

  @@index([workOrderId])
  @@index([materialLotId])
  @@index([materialCode])
  @@map("inventory_reservations")
}

model WorkOrderOperation {
  id              String  @id @default(uuid())
  workOrderId     String  @map("work_order_id")
  stationId       String  @map("station_id")
  sequence        Int
  estimatedMinutes Int?   @map("estimated_minutes")
  status          String  @default("pending") // pending | in_progress | completed
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workOrder  WorkOrder                @relation(fields: [workOrderId], references: [id])
  station    Station                  @relation(fields: [stationId], references: [id])
  executions UnitOperationExecution[]

  @@unique([workOrderId, sequence])
  @@index([stationId])
  @@map("work_order_operations")
}

model Unit {
  id               String   @id @default(uuid())
  workOrderId      String   @map("work_order_id")
  serialNumber     String   @unique @map("serial_number")
  serialAssigned   Boolean  @default(false) @map("serial_assigned")
  status           String   @default("created") // created | in_progress | completed | scrapped | rework
  currentStationId String?  @map("current_station_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workOrder            WorkOrder                 @relation(fields: [workOrderId], references: [id])
  executions           UnitOperationExecution[]
  materialConsumptions UnitMaterialConsumption[]
  qualityResults       QualityCheckResult[]
  ncrs                 NonconformanceRecord[]
  eolTestResults       EolTestResult[]

  @@index([workOrderId])
  @@index([status])
  @@index([currentStationId])
  @@map("units")
}

model UnitOperationExecution {
  id               String    @id @default(uuid())
  unitId           String    @map("unit_id")
  operationId      String    @map("operation_id")
  stationId        String    @map("station_id")
  operatorId       String    @map("operator_id")
  startedAt        DateTime  @map("started_at")
  completedAt      DateTime? @map("completed_at")
  cycleTimeMinutes Float?    @map("cycle_time_minutes")
  result           String?   // pass | fail | rework
  isRework         Boolean   @default(false) @map("is_rework")
  attemptNumber    Int       @default(1) @map("attempt_number")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  unit         Unit               @relation(fields: [unitId], references: [id])
  operation    WorkOrderOperation @relation(fields: [operationId], references: [id])
  station      Station            @relation(fields: [stationId], references: [id])
  operator     User               @relation(fields: [operatorId], references: [id])
  dataCaptures StepDataCapture[]

  @@index([unitId])
  @@index([stationId, startedAt])
  @@index([stationId, completedAt])
  @@index([operatorId, completedAt])
  @@map("unit_operation_executions")
}

// =============================================================================
// TRACEABILITY (GS1-aligned)
// =============================================================================

model MaterialLot {
  id                  String   @id @default(uuid())
  lotNumber           String   @unique @map("lot_number")
  materialCode        String   @map("material_code")
  description         String?
  qtyReceived         Float    @map("qty_received")
  qtyRemaining        Float    @map("qty_remaining")
  qtyReserved         Float    @default(0) @map("qty_reserved")
  unitOfMeasure       String   @default("EA") @map("unit_of_measure")
  supplier            String?
  purchaseOrderNumber String?  @map("purchase_order_number")
  status              String   @default("available") // available | quarantine | expired | depleted | pending_iqc
  receivedById        String?  @map("received_by_id")
  receivedAt          DateTime @default(now()) @map("received_at")
  expiresAt           DateTime? @map("expires_at")
  carrier             String?
  trackingNumber      String?  @map("tracking_number")
  conditionNotes      String?  @map("condition_notes")
  poLineItemId        String?  @map("po_line_item_id") // Link to PO line that was received
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  supplierId       String?  @map("supplier_id")

  receivedBy       User?                    @relation("ReceivedMaterialLots", fields: [receivedById], references: [id])
  supplierRef      Supplier?                @relation(fields: [supplierId], references: [id])
  consumptions            UnitMaterialConsumption[]
  kitLines                KitLine[]
  ctqMeasurements         CTQMeasurement[]
  inventoryTransactions   InventoryTransaction[]
  reservations            InventoryReservation[]
  incomingInspections     IncomingInspection[]
  ncrs                    NonconformanceRecord[]

  @@index([materialCode])
  @@index([status])
  @@index([status, qtyRemaining])
  @@index([purchaseOrderNumber])
  @@map("material_lots")
}

model UnitMaterialConsumption {
  id            String   @id @default(uuid())
  unitId        String   @map("unit_id")
  materialLotId String   @map("material_lot_id")
  qtyConsumed   Float    @map("qty_consumed")
  stationId     String   @map("station_id")
  operatorId    String   @map("operator_id")
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")

  unit        Unit        @relation(fields: [unitId], references: [id])
  materialLot MaterialLot @relation(fields: [materialLotId], references: [id])
  station     Station     @relation(fields: [stationId], references: [id])
  operator    User        @relation(fields: [operatorId], references: [id])

  @@index([unitId])
  @@index([materialLotId])
  @@map("unit_material_consumptions")
}

// =============================================================================
// QUALITY & NCR
// =============================================================================

model QualityCheckResult {
  id           String   @id @default(uuid())
  unitId       String   @map("unit_id")
  definitionId String   @map("definition_id")
  operatorId   String   @map("operator_id")
  result       String   // pass | fail
  valuesJson   Json     @map("values_json") // Measurements, checkbox states, etc.
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now()) @map("created_at")

  unit       Unit                   @relation(fields: [unitId], references: [id])
  definition QualityCheckDefinition @relation(fields: [definitionId], references: [id])
  operator   User                   @relation(fields: [operatorId], references: [id])

  @@index([unitId])
  @@index([timestamp])
  @@index([definitionId, timestamp])
  @@map("quality_check_results")
}

model NonconformanceRecord {
  id                String    @id @default(uuid())
  ncrNumber         String?   @unique @map("ncr_number") // Human-readable e.g., NCR-2026-0042
  unitId            String?   @map("unit_id") // Nullable: can be unit-based OR lot-based
  stationId         String?   @map("station_id") // Nullable: IQC NCRs don't have a station
  materialLotId     String?   @map("material_lot_id") // For IQC NCRs
  purchaseOrderId   String?   @map("purchase_order_id") // Link to originating PO
  defectType        String    @map("defect_type")
  description       String?
  partNumber        String?   @map("part_number")
  partRevision      String?   @map("part_revision")
  affectedQty       Float?    @map("affected_qty")
  failedDimensions  Json?     @map("failed_dimensions") // Array of { ctqId, measured, nominal, usl, lsl }
  disposition       String?   // rework | scrap | use_as_is | defer
  dispositionRationale String? @map("disposition_rationale")
  correctiveAction  String?   @map("corrective_action")
  responsibleParty  String?   @map("responsible_party")
  actionDueDate     DateTime? @map("action_due_date")
  supplierNotified  Boolean   @default(false) @map("supplier_notified")
  supplierNotifiedAt DateTime? @map("supplier_notified_at")
  severity          String    @default("minor") // minor | major | critical
  status            String    @default("open") // open | dispositioned | closed
  source            String    @default("production") // production | iqc
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  closedAt          DateTime? @map("closed_at")

  unit        Unit?        @relation(fields: [unitId], references: [id])
  station     Station?     @relation(fields: [stationId], references: [id])
  materialLot MaterialLot? @relation(fields: [materialLotId], references: [id])

  @@index([unitId])
  @@index([materialLotId])
  @@index([status])
  @@index([stationId, status])
  @@map("nonconformance_records")
}

// =============================================================================
// DOWNTIME
// =============================================================================

model DowntimeInterval {
  id         String    @id @default(uuid())
  stationId  String    @map("station_id")
  reasonId   String?   @map("reason_id")
  operatorId String    @map("operator_id")
  startedAt  DateTime  @map("started_at")
  endedAt    DateTime? @map("ended_at")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  station  Station         @relation(fields: [stationId], references: [id])
  reason   DowntimeReason? @relation(fields: [reasonId], references: [id])
  operator User            @relation(fields: [operatorId], references: [id])

  @@index([stationId, startedAt])
  @@map("downtime_intervals")
}

// =============================================================================
// KITTING
// =============================================================================

model Kit {
  id          String    @id @default(uuid())
  workOrderId String    @unique @map("work_order_id")
  status      String    @default("pending") // pending | in_progress | complete | issued
  createdById String    @map("created_by_id")
  issuedAt    DateTime? @map("issued_at")
  issuedById  String?   @map("issued_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  createdBy User      @relation("KitCreator", fields: [createdById], references: [id])
  issuedBy  User?     @relation("KitIssuer", fields: [issuedById], references: [id])
  lines     KitLine[]

  @@index([status])
  @@map("kits")
}

model KitLine {
  id            String    @id @default(uuid())
  kitId         String    @map("kit_id")
  materialCode  String    @map("material_code")
  description   String?
  qtyRequired   Float     @map("qty_required")
  qtyPicked     Float     @default(0) @map("qty_picked")
  materialLotId String?   @map("material_lot_id")
  pickedById    String?   @map("picked_by_id")
  pickedAt      DateTime? @map("picked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  kit         Kit          @relation(fields: [kitId], references: [id])
  materialLot MaterialLot? @relation(fields: [materialLotId], references: [id])
  pickedBy    User?        @relation("KitLinePicker", fields: [pickedById], references: [id])

  @@index([kitId])
  @@map("kit_lines")
}

// =============================================================================
// CTQ (Critical-to-Quality) DEFINITIONS - Incoming Quality Control
// =============================================================================

model CTQDefinition {
  id              String   @id @default(uuid())
  partNumber      String   @map("part_number")
  revision        String   @default("A")
  dimensionName   String   @map("dimension_name")
  nominal         Float
  usl             Float    // Upper specification limit
  lsl             Float    // Lower specification limit
  unitOfMeasure   String   @map("unit_of_measure")
  measurementTool String?  @map("measurement_tool")
  methodNote      String?  @map("method_note")
  sampleSizeRule  String   @default("all") @map("sample_size_rule") // all | fixed_count | aql | skip
  sampleSize      Int?     @map("sample_size")
  safetyCritical  Boolean  @default(false) @map("safety_critical")
  source          String   @default("manual") // manual | extracted
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  measurements CTQMeasurement[]
  iqcResults   IQCResult[]

  @@index([partNumber, revision])
  @@map("ctq_definitions")
}

model CTQMeasurement {
  id              String   @id @default(uuid())
  ctqDefinitionId String   @map("ctq_definition_id")
  materialLotId   String?  @map("material_lot_id")
  sampleNumber    Int      @map("sample_number")
  measuredValue   Float    @map("measured_value")
  result          String   // pass | fail
  inspectorId     String   @map("inspector_id")
  notes           String?
  measuredAt      DateTime @default(now()) @map("measured_at")
  createdAt       DateTime @default(now()) @map("created_at")

  ctqDefinition CTQDefinition @relation(fields: [ctqDefinitionId], references: [id])
  materialLot   MaterialLot?  @relation(fields: [materialLotId], references: [id])
  inspector     User          @relation(fields: [inspectorId], references: [id])

  @@index([ctqDefinitionId])
  @@index([materialLotId])
  @@map("ctq_measurements")
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String   // create | update | delete | config_change
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, timestamp])
  @@map("audit_logs")
}

// =============================================================================
// AI MONITORING AGENT
// =============================================================================

model AIInsight {
  id             String    @id @default(uuid())
  siteId         String    @map("site_id")
  stationId      String?   @map("station_id")
  insightType    String    @map("insight_type") // anomaly | recommendation | prediction
  severity       String    // info | warning | critical
  title          String
  description    String
  payload        Json      @default("{}")
  confidence     Float     @default(0.8)
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime? @map("acknowledged_at")
  acknowledgedBy String?   @map("acknowledged_by")
  createdAt      DateTime  @default(now()) @map("created_at")

  site    Site     @relation(fields: [siteId], references: [id])
  station Station? @relation(fields: [stationId], references: [id])

  @@index([siteId, createdAt])
  @@index([severity, acknowledged])
  @@map("ai_insights")
}

model AIConversation {
  id        String   @id @default(uuid())
  siteId    String   @map("site_id")
  userId    String   @map("user_id")
  messages  Json     @default("[]") // Array of {role, content, timestamp}
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

// =============================================================================
// SHIFT MANAGEMENT
// =============================================================================

model Shift {
  id        String   @id @default(uuid())
  siteId    String   @map("site_id")
  name      String   // e.g., "Day Shift", "Night Shift"
  startTime String   @map("start_time") // e.g., "06:00" (24h format)
  endTime   String   @map("end_time")   // e.g., "14:00"
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id])

  @@map("shifts")
}

// =============================================================================
// PART MASTER & SUPPLIER CATALOG
// =============================================================================

model PartMaster {
  id               String   @id @default(uuid())
  partNumber       String   @unique @map("part_number") // e.g., 510-00001
  name             String
  description      String?
  revision         String   @default("A")
  category         String   @default("component") // component | raw_material | consumable | subassembly | finished_good
  unitOfMeasure    String   @default("EA") @map("unit_of_measure")
  countryOfOrigin  String?  @map("country_of_origin")
  reorderPoint     Float?   @map("reorder_point")
  targetStockLevel Float?   @map("target_stock_level")
  standardCost     Float?   @map("standard_cost")
  serializationType String  @default("none") @map("serialization_type") // none | serial | lot | both
  hazardous        Boolean  @default(false)
  hazardousNotes   String?  @map("hazardous_notes")
  status           String   @default("active") // active | obsolete | pending_approval
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  suppliers PartSupplier[]

  @@map("part_masters")
}

model Supplier {
  id                  String   @id @default(uuid())
  name                String
  supplierId          String   @unique @map("supplier_id") // e.g., SUP-001
  contactEmail        String?  @map("contact_email")
  contactPhone        String?  @map("contact_phone")
  address             String?
  countryOfOrigin     String?  @map("country_of_origin")
  qualificationStatus String   @default("pending") @map("qualification_status") // pending | qualified | conditional | disqualified
  notes               String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  parts          PartSupplier[]
  materialLots   MaterialLot[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PartSupplier {
  id                 String  @id @default(uuid())
  partId             String  @map("part_id")
  supplierId         String  @map("supplier_id")
  supplierPartNumber String? @map("supplier_part_number")
  isPreferred        Boolean @default(false) @map("is_preferred")
  unitCost           Float?  @map("unit_cost")
  leadTimeDays       Int?    @map("lead_time_days")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  part     PartMaster @relation(fields: [partId], references: [id])
  supplier Supplier   @relation(fields: [supplierId], references: [id])

  @@unique([partId, supplierId])
  @@map("part_suppliers")
}

// =============================================================================
// PROCUREMENT & PURCHASE ORDERS
// =============================================================================

model PurchaseOrder {
  id              String    @id @default(uuid())
  poNumber        String    @unique @map("po_number") // e.g., PO-2026-0001
  supplierId      String    @map("supplier_id")
  buyerName       String    @map("buyer_name")
  orderDate       DateTime  @default(now()) @map("order_date")
  expectedDate    DateTime? @map("expected_date")
  status          String    @default("draft") // draft | submitted | partially_received | fully_received | closed | cancelled
  currency        String    @default("USD")
  paymentTerms    String?   @map("payment_terms")
  shippingMethod  String?   @map("shipping_method")
  totalValue      Float?    @map("total_value")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  supplier  Supplier              @relation(fields: [supplierId], references: [id])
  lineItems PurchaseOrderLineItem[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id                String  @id @default(uuid())
  purchaseOrderId   String  @map("purchase_order_id")
  lineNumber        Int     @map("line_number")
  partNumber        String  @map("part_number") // References PartMaster.partNumber
  partRevision      String  @default("A") @map("part_revision")
  supplierPartNumber String? @map("supplier_part_number")
  description       String?
  qtyOrdered        Float   @map("qty_ordered")
  qtyReceived       Float   @default(0) @map("qty_received")
  unitOfMeasure     String  @default("EA") @map("unit_of_measure")
  unitCost          Float?  @map("unit_cost")
  totalCost         Float?  @map("total_cost")
  countryOfOrigin   String? @map("country_of_origin")
  expectedLeadTimeDays Int? @map("expected_lead_time_days")
  drawingUrl        String? @map("drawing_url") // URL/path to revision-controlled drawing
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, lineNumber])
  @@index([partNumber])
  @@map("purchase_order_line_items")
}

// =============================================================================
// INCOMING QUALITY CONTROL (IQC)
// =============================================================================

model IncomingInspection {
  id              String    @id @default(uuid())
  materialLotId   String    @map("material_lot_id")
  inspectorId     String?   @map("inspector_id")
  status          String    @default("pending") // pending | in_progress | completed | rejected
  overallResult   String?   @map("overall_result") // conforming | nonconforming_rework | nonconforming_uai | nonconforming_scrap
  dispositionNotes String?  @map("disposition_notes")
  approvedById    String?   @map("approved_by_id") // For UAI: engineer sign-off
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  materialLot  MaterialLot    @relation(fields: [materialLotId], references: [id])
  inspector    User?          @relation("IQCInspector", fields: [inspectorId], references: [id])
  approvedBy   User?          @relation("IQCApprover", fields: [approvedById], references: [id])
  results      IQCResult[]

  @@index([materialLotId])
  @@index([status])
  @@index([inspectorId])
  @@map("incoming_inspections")
}

model IQCResult {
  id              String   @id @default(uuid())
  inspectionId    String   @map("inspection_id")
  ctqDefinitionId String   @map("ctq_definition_id")
  sampleNumber    Int      @map("sample_number")
  measuredValue   Float    @map("measured_value")
  result          String   // pass | fail
  inspectorId     String   @map("inspector_id")
  notes           String?
  measuredAt      DateTime @default(now()) @map("measured_at")
  createdAt       DateTime @default(now()) @map("created_at")

  inspection    IncomingInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  ctqDefinition CTQDefinition     @relation(fields: [ctqDefinitionId], references: [id])
  inspector     User               @relation("IQCResultInspector", fields: [inspectorId], references: [id])

  @@index([inspectionId])
  @@index([ctqDefinitionId])
  @@map("iqc_results")
}

// =============================================================================
// PROCESS STEP DEFINITIONS & DATA CAPTURE
// =============================================================================

model ProcessStepDefinition {
  id              String   @id @default(uuid())
  name            String   // e.g., "Winding", "Press shaft into bell"
  description     String?
  category        String   // stator_production, stator_electrical, wire_harness, base_assembly, rotor_assembly, final_assembly, packaging
  stationId       String?  @map("station_id")
  sequenceOrder   Int      @default(0) @map("sequence_order")
  isMandatory     Boolean  @default(true) @map("is_mandatory")
  requiresSignoff Boolean  @default(false) @map("requires_signoff")
  triggersQc      Boolean  @default(false) @map("triggers_qc")
  cycleTimeTarget Float?   @map("cycle_time_target") // Minutes
  dataFields      Json     @default("[]") @map("data_fields") // Array of DataFieldDefinition
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  station      Station?          @relation(fields: [stationId], references: [id])
  dataCaptures StepDataCapture[]

  @@map("process_step_definitions")
}

model StepDataCapture {
  id               String    @id @default(uuid())
  executionId      String    @map("execution_id")
  stepDefinitionId String    @map("step_definition_id")
  capturedData     Json      @map("captured_data") // Key-value pairs matching dataFields
  operatorId       String    @map("operator_id")
  signedOff        Boolean   @default(false) @map("signed_off")
  signedOffAt      DateTime? @map("signed_off_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  execution      UnitOperationExecution @relation(fields: [executionId], references: [id])
  stepDefinition ProcessStepDefinition  @relation(fields: [stepDefinitionId], references: [id])
  operator       User                   @relation(fields: [operatorId], references: [id])

  @@unique([executionId, stepDefinitionId])
  @@map("step_data_captures")
}

// =============================================================================
// EOL (END-OF-LINE) TESTING
// =============================================================================

model EolTestSuite {
  id          String   @id @default(uuid())
  routingId   String   @map("routing_id")
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  routing    Routing            @relation(fields: [routingId], references: [id])
  parameters EolTestParameter[]
  results    EolTestResult[]

  @@index([routingId])
  @@map("eol_test_suites")
}

model EolTestParameter {
  id          String   @id @default(uuid())
  suiteId     String   @map("suite_id")
  name        String
  unit        String
  minValue    Float?   @map("min_value")
  maxValue    Float?   @map("max_value")
  targetValue Float?   @map("target_value")
  sequence    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  suite EolTestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)

  @@index([suiteId])
  @@map("eol_test_parameters")
}

model EolTestResult {
  id              String   @id @default(uuid())
  unitId          String   @map("unit_id")
  suiteId         String   @map("suite_id")
  operatorId      String   @map("operator_id")
  compositeResult String   @map("composite_result") // pass | fail
  parameterResults Json    @map("parameter_results") // Array of { parameterId, value, pass }
  notes           String?
  testedAt        DateTime @default(now()) @map("tested_at")
  createdAt       DateTime @default(now()) @map("created_at")

  unit  Unit         @relation(fields: [unitId], references: [id])
  suite EolTestSuite @relation(fields: [suiteId], references: [id])

  @@index([unitId])
  @@index([suiteId])
  @@map("eol_test_results")
}

// =============================================================================
// INVENTORY TRANSACTION LEDGER (Append-only)
// =============================================================================

model InventoryTransaction {
  id              String   @id @default(uuid())
  materialLotId   String   @map("material_lot_id")
  transactionType String   @map("transaction_type") // receive | issue | return | scrap | adjustment | transfer
  quantity        Float    // positive = increase, negative = decrease
  previousQty     Float    @map("previous_qty")
  newQty          Float    @map("new_qty")
  referenceType   String?  @map("reference_type") // work_order | kit | ncr | manual
  referenceId     String?  @map("reference_id")
  reason          String?
  operatorId      String   @map("operator_id")
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")

  materialLot MaterialLot @relation(fields: [materialLotId], references: [id])
  operator    User        @relation("InventoryTransactions", fields: [operatorId], references: [id])

  @@index([materialLotId, timestamp])
  @@index([transactionType])
  @@index([referenceType, referenceId])
  @@index([operatorId, timestamp])
  @@map("inventory_transactions")
}

// =============================================================================
// SHIPPING & FULFILLMENT
// =============================================================================

model Shipment {
  id              String    @id @default(uuid())
  shipmentNumber  String    @unique @map("shipment_number") // e.g., SHP-2026-0001
  workOrderId     String    @map("work_order_id")
  customerName    String    @map("customer_name")
  customerAddress String?   @map("customer_address")
  shipDate        DateTime? @map("ship_date")
  carrier         String?
  trackingNumber  String?   @map("tracking_number")
  packingListUrl  String?   @map("packing_list_url")
  cocUrl          String?   @map("coc_url")
  totalBoxes      Int?      @map("total_boxes")
  totalWeight     Float?    @map("total_weight")
  weightUnit      String    @default("lbs") @map("weight_unit")
  specialNotes    String?   @map("special_notes")
  status          String    @default("pending") // pending | packed | shipped | delivered
  shippedById     String?   @map("shipped_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workOrder WorkOrder    @relation(fields: [workOrderId], references: [id])
  shippedBy User?        @relation("ShipmentShipper", fields: [shippedById], references: [id])
  lines     ShipmentLine[]

  @@index([workOrderId])
  @@index([status])
  @@map("shipments")
}

model ShipmentLine {
  id           String   @id @default(uuid())
  shipmentId   String   @map("shipment_id")
  unitId       String   @map("unit_id")
  serialNumber String   @map("serial_number")
  boxNumber    Int?     @map("box_number")
  createdAt    DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_lines")
}

// =============================================================================
// WEBHOOK SUBSCRIPTIONS & DELIVERY
// =============================================================================

model WebhookSubscription {
  id        String   @id @default(uuid())
  name      String
  url       String
  secret    String   // HMAC signing secret
  events    String[] // Array of event types to subscribe to
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id             String    @id @default(uuid())
  subscriptionId String    @map("subscription_id")
  eventType      String    @map("event_type")
  payload        Json
  statusCode     Int?      @map("status_code")
  responseBody   String?   @map("response_body")
  attempts       Int       @default(0)
  lastAttemptAt  DateTime? @map("last_attempt_at")
  deliveredAt    DateTime? @map("delivered_at")
  status         String    @default("pending") // pending | delivered | failed
  createdAt      DateTime  @default(now()) @map("created_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  title      String
  message    String
  type       String    @default("info") // info | warning | error | success
  category   String    @default("system") // system | quality | production | shipping | inventory
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  read       Boolean   @default(false)
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// API KEYS (Machine-to-Machine Authentication)
// =============================================================================

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique @map("key_hash") // SHA-256 hash of the actual key
  keyPrefix   String    @map("key_prefix") // First 8 chars for display, e.g., "mes_1234..."
  permissions String[]  // Array of permission strings
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  active      Boolean   @default(true)
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy User @relation("ApiKeyCreator", fields: [createdById], references: [id])

  @@map("api_keys")
}
